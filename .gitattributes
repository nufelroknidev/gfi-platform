# Tell GitHub Linguist to ignore Django templates, static assets,
# and generated files — so the language bar reflects the actual
# backend language (Python) rather than markup and styles.

templates/**     linguist-detectable=false
static/css/**    linguist-detectable=false
static/js/**     linguist-detectable=false
static/img/**    linguist-detectable=false
locale/**        linguist-detectable=false
