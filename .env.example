# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CANONICAL_DOMAIN=https://www.generalfoodindustry.com

# Database
# Development (SQLite — default, no config needed)
DATABASE_URL=sqlite:///db.sqlite3
# Production (PostgreSQL on AWS RDS)
# DATABASE_URL=postgres://user:password@host:5432/dbname

# Email (Brevo SMTP — free tier 300/day, stops at limit, no charges)
# SMTP login is the Brevo-assigned address shown under Settings → SMTP & API → Login
# SMTP password is the generated SMTP key (read via JS from modal, not screenshot)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
# EMAIL_HOST_USER=xxxxxxxx@smtp-brevo.com
# EMAIL_HOST_PASSWORD=xsmtpsib-...
# DEFAULT_FROM_EMAIL=noreply@generalfoodindustry.com
# CONTACT_EMAIL=sales@generalfoodindustry.com

# AWS (Phase 11)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=ap-southeast-1
# AWS_CLOUDFRONT_DOMAIN=

# Google Analytics (Phase 9)
# GA4_MEASUREMENT_ID=G-XXXXXXXXXX
